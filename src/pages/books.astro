---
import Layout from '../layouts/Layout.astro';
import bookMockup from '../assets/BOJ_MockUp.jpg';
import bookCover from '../assets/TheBookOfJacobFrontCover.jpg';
---

<Layout>
  <main class="books-page">
    <section class="books-hero">
      <div class="hero-copy">
        <p class="eyebrow">Books</p>
        <h1>The Book of Jacob</h1>
        <p class="intro">
          A sweeping post-apocalyptic adventure by J.L. Burnes.
        </p>
        <div class="hero-note">
          <span class="note-label">Now Featured</span>
          <p>
            Available for free with Kindle Unlimited on Amazon.
          </p>
          <a
            class="amazon-link"
            href="https://amzn.to/4dBlOyh"
            target="_blank"
            rel="noopener"
            aria-label="View The Book of Jacob on Amazon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 16 16"
              aria-hidden="true"
            >
              <path d="M10.813 11.968c.157.083.36.074.5-.05l.005.005a90 90 0 0 1 1.623-1.405c.173-.143.143-.372.006-.563l-.125-.17c-.345-.465-.673-.906-.673-1.791v-3.3l.001-.335c.008-1.265.014-2.421-.933-3.305C10.404.274 9.06 0 8.03 0 6.017 0 3.77.75 3.296 3.24c-.047.264.143.404.316.443l2.054.22c.19-.009.33-.196.366-.387.176-.857.896-1.271 1.703-1.271.435 0 .929.16 1.188.55.264.39.26.91.257 1.376v.432q-.3.033-.621.065c-1.113.114-2.397.246-3.36.67C3.873 5.91 2.94 7.08 2.94 8.798c0 2.2 1.387 3.298 3.168 3.298 1.506 0 2.328-.354 3.489-1.54l.167.246c.274.405.456.675 1.047 1.166ZM6.03 8.431C6.03 6.627 7.647 6.3 9.177 6.3v.57c.001.776.002 1.434-.396 2.133-.336.595-.87.961-1.465.961-.812 0-1.286-.619-1.286-1.533M.435 12.174c2.629 1.603 6.698 4.084 13.183.997.28-.116.475.078.199.431C13.538 13.96 11.312 16 7.57 16 3.832 16 .968 13.446.094 12.386c-.24-.275.036-.4.199-.299z"/>
              <path d="M13.828 11.943c.567-.07 1.468-.027 1.645.204.135.176-.004.966-.233 1.533-.23.563-.572.961-.762 1.115s-.333.094-.23-.137c.105-.23.684-1.663.455-1.963-.213-.278-1.177-.177-1.625-.13l-.09.009q-.142.013-.233.024c-.193.021-.245.027-.274-.032-.074-.209.779-.556 1.347-.623"/>
            </svg>
            <span>View on Amazon</span>
          </a>
        </div>
      </div>

      <div class="hero-art">
        <div class="mockup-shell">
          <img src={bookMockup.src} alt="The Book of Jacob mockup" />
        </div>
      </div>
    </section>

    <section class="book-spotlight">
      <div class="cover-panel">
        <div class="cover-frame">
          <img src={bookCover.src} alt="The Book of Jacob cover" />
        </div>
      </div>

      <article class="book-card">
        <p class="card-kicker">Featured Book</p>
        <h2>The Book of Jacob</h2>
        <p class="author-line">By J.L. Burnes</p>

        <div class="meta-row">
          <span>Science Fiction</span>
          <span>Post-Apocalyptic</span>
          <span>Adventure</span>
          <span>Available Now</span>
        </div>

        <div class="description">
          <p>
            In a world buried beneath endless desert, humanity survives atop colossal eight-legged
            walking machines known as sand walkers. Jacob, a solitary scavenger, roams the dunes
            in search of fuel and supplies while chasing a story his mother once told him about an
            ocean hidden somewhere to the south.
          </p>
          <p>
            After a battle between giants leaves wreckage scattered across the sands, Jacob seizes
            the chance to gather what he needs for the journey. Everything changes when he discovers
            Tyler, a frightened boy piloting his own walker, and against every instinct chooses to
            spare him.
          </p>
          <p>
            Together they head south toward the mythical ocean, facing pirates, relentless heat,
            and a changing world where the first signs of life have begun to return. What starts as
            a desperate search for survival grows into a story of hope, healing, and a journey that
            may alter the fate of humanity itself.
          </p>
        </div>

        <div class="callouts">
          <div class="callout">
            <h3>What It Delivers</h3>
            <p>Adventure, sci-fi, post-apocalyptic stakes, and just a dash of steampunk.</p>
          </div>
          <div class="callout">
            <h3>For Readers Of</h3>
            <p>The Road, Mortal Engines, and The Book of Eli.</p>
          </div>
        </div>
      </article>
    </section>
  </main>
</Layout>

<style>
  .books-page {
    min-height: 100vh;
    padding: 3rem 1.5rem 5rem;
    background:
      radial-gradient(circle at top left, rgba(200, 169, 107, 0.1), transparent 28%),
      radial-gradient(circle at 90% 15%, rgba(37, 168, 214, 0.12), transparent 26%);
  }

  .books-hero,
  .book-spotlight {
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .books-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 520px);
    gap: 2.5rem;
    align-items: center;
    padding: 2rem 0 4rem;
  }

  .hero-copy {
    max-width: 40rem;
    animation: fadeUp 0.6s ease both;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.82rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text);
    animation: fadeUp 0.6s ease 0.08s both;
  }

  .intro {
    margin: 1.5rem 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.9;
    max-width: 39rem;
    animation: fadeUp 0.6s ease 0.16s both;
  }

  .hero-note {
    margin-top: 1.75rem;
    padding: 1.25rem 1.35rem;
    border: 1px solid rgba(200, 169, 107, 0.16);
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(34, 39, 52, 0.72), rgba(23, 26, 33, 0.72));
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
    animation: fadeUp 0.6s ease 0.24s both;
  }

  .note-label,
  .card-kicker {
    display: inline-block;
    margin-bottom: 0.55rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
  }

  .hero-note p,
  .description p,
  .callout p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .amazon-link {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1rem;
    min-height: 3rem;
    padding: 0 1.15rem 0 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    color: #101216;
    background: linear-gradient(135deg, #f7d57a 0%, #e7b94e 100%);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .amazon-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
  }

  .amazon-link svg {
    width: 1.2rem;
    height: 1.2rem;
    flex: 0 0 auto;
    fill: currentColor;
  }

  .amazon-link span {
    font-size: 0.96rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .hero-art {
    display: flex;
    justify-content: center;
    animation: fadeUp 0.6s ease 0.18s both;
  }

  .mockup-shell {
    position: relative;
    width: min(100%, 500px);
    padding: 1rem;
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(34, 39, 52, 0.92), rgba(23, 26, 33, 0.92));
    border: 1px solid rgba(200, 169, 107, 0.12);
    box-shadow: var(--shadow);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .mockup-shell::before {
    content: '';
    position: absolute;
    inset: 14px;
    border-radius: 24px;
    background:
      radial-gradient(circle at top, rgba(37, 168, 214, 0.12), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
    pointer-events: none;
  }

  .mockup-shell img {
    position: relative;
    z-index: 1;
    width: 100%;
    border-radius: 24px;
    transition: transform 0.45s ease;
  }

  .mockup-shell:hover {
    transform: translateY(-6px);
    border-color: rgba(200, 169, 107, 0.24);
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
  }

  .mockup-shell:hover img {
    transform: scale(1.02);
  }

  .book-spotlight {
    display: grid;
    grid-template-columns: minmax(250px, 340px) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
    animation: fadeUp 0.6s ease 0.34s both;
  }

  .cover-panel {
    position: sticky;
    top: 7rem;
  }

  .cover-frame,
  .book-card {
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(34, 39, 52, 0.92), rgba(23, 26, 33, 0.92));
    border: 1px solid rgba(200, 169, 107, 0.12);
    box-shadow: var(--shadow);
  }

  .cover-frame {
    padding: 1rem;
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .cover-frame img {
    width: 100%;
    border-radius: 20px;
    transition: transform 0.45s ease;
  }

  .cover-frame:hover {
    transform: translateY(-6px);
    border-color: rgba(200, 169, 107, 0.22);
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.34);
  }

  .cover-frame:hover img {
    transform: scale(1.02);
  }

  .book-card {
    padding: 2rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 3rem);
    color: var(--text);
    line-height: 1;
  }

  .author-line {
    margin: 0.6rem 0 0;
    color: var(--text-muted);
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .meta-row span {
    display: inline-flex;
    align-items: center;
    min-height: 2.4rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    background: rgba(200, 169, 107, 0.08);
    border: 1px solid rgba(200, 169, 107, 0.18);
    color: var(--text);
    font-size: 0.92rem;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .meta-row span:hover {
    transform: translateY(-2px);
    border-color: rgba(200, 169, 107, 0.32);
    background: rgba(200, 169, 107, 0.14);
  }

  .description {
    display: grid;
    gap: 1rem;
  }

  .callouts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .callout {
    padding: 1.1rem 1.15rem;
    border-radius: 20px;
    background: rgba(200, 169, 107, 0.05);
    border: 1px solid rgba(200, 169, 107, 0.1);
  }

  h3 {
    margin: 0 0 0.45rem;
    color: var(--text);
    font-size: 1rem;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .books-hero,
    .book-spotlight {
      grid-template-columns: 1fr;
    }

    .cover-panel {
      position: static;
      max-width: 320px;
    }

    .hero-art,
    .cover-panel {
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .books-page {
      padding-inline: 1rem;
    }

    .book-card {
      padding: 1.4rem;
    }

    .callouts {
      grid-template-columns: 1fr;
    }
  }
</style>
