---
import Layout from '../layouts/Layout.astro';

const feedUrl = 'https://jlburnes.substack.com/feed';
const substackUrl = 'https://jlburnes.substack.com/';

type Post = {
  title: string;
  link: string;
  description: string;
  pubDate: string;
};

function decodeHtml(value: string) {
  return value
    .replace(/<!\[CDATA\[(.*?)\]\]>/gs, '$1')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>');
}

function stripHtml(value: string) {
  return decodeHtml(value)
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function getTagValue(block: string, tag: string) {
  const match = block.match(new RegExp(`<${tag}>([\\s\\S]*?)<\\/${tag}>`, 'i'));
  return match ? match[1].trim() : '';
}

function parseRss(xml: string): Post[] {
  const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/gi)];

  return items.map((match) => {
    const item = match[1];
    const title = decodeHtml(getTagValue(item, 'title')) || 'Untitled post';
    const link = decodeHtml(getTagValue(item, 'link')) || substackUrl;
    const pubDate = getTagValue(item, 'pubDate');
    const descriptionSource =
      getTagValue(item, 'description') || getTagValue(item, 'content:encoded');
    const description = stripHtml(descriptionSource);

    return {
      title,
      link,
      pubDate,
      description,
    };
  });
}

function excerpt(text: string, maxLength = 220) {
  if (text.length <= maxLength) return text;
  return `${text.slice(0, maxLength).trimEnd()}...`;
}

let posts: Post[] = [];
let feedError = false;

try {
  const response = await fetch(feedUrl);
  if (!response.ok) {
    throw new Error(`Feed request failed with ${response.status}`);
  }

  const xml = await response.text();
  posts = parseRss(xml).slice(0, 6);
} catch (error) {
  feedError = true;
}
---

<Layout>
  <main class="blog-page">
    <section class="blog-hero">
      <div class="hero-copy">
        <p class="eyebrow">Blog</p>
        <h1>Essays on writing and other things</h1>
        <p class="intro">
          Recent posts from J.L. Burnes's Substack, "On Writing and Other Things."
        </p>
      </div>

      <div class="hero-actions">
        <a class="primary-link" href={substackUrl} target="_blank" rel="noopener">
          Visit the Substack
        </a>
        <a class="secondary-link" href={feedUrl} target="_blank" rel="noopener">
          View RSS Feed
        </a>
      </div>
    </section>

    {posts.length > 0 ? (
      <section class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <p class="post-date">
              {post.pubDate
                ? new Date(post.pubDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })
                : 'Recent Post'}
            </p>
            <h2>{post.title}</h2>
            <p class="post-excerpt">{excerpt(post.description || 'Read the latest post on Substack.')}</p>
            <a class="post-link" href={post.link} target="_blank" rel="noopener">
              Read on Substack
            </a>
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <div class="empty-card">
          <p class="eyebrow">Substack Feed</p>
          <h2>Posts will appear here automatically.</h2>
          <p>
            {feedError
              ? 'The feed could not be loaded at build time, but the page is ready. Once the feed responds, recent posts will populate here automatically.'
              : 'As new posts are published to Substack, this page will pull them into the site from the RSS feed.'}
          </p>
          <a class="primary-link" href={substackUrl} target="_blank" rel="noopener">
            Open the Substack
          </a>
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .blog-page {
    min-height: 100vh;
    padding: 3rem 1.5rem 5rem;
    background:
      radial-gradient(circle at top left, rgba(200, 169, 107, 0.12), transparent 28%),
      radial-gradient(circle at 88% 8%, rgba(37, 168, 214, 0.1), transparent 24%);
  }

  .blog-hero,
  .posts-grid,
  .empty-state {
    width: min(1160px, 100%);
    margin: 0 auto;
  }

  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    padding: 2rem 0 3rem;
    animation: fadeUp 0.6s ease both;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.82rem;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text);
    animation: fadeUp 0.6s ease 0.08s both;
  }

  .intro {
    max-width: 44rem;
    margin: 1.4rem 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.9;
    animation: fadeUp 0.6s ease 0.16s both;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    animation: fadeUp 0.6s ease 0.22s both;
  }

  .primary-link,
  .secondary-link,
  .post-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0 1.2rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .primary-link {
    color: #101216;
    background: linear-gradient(135deg, #d7bc86 0%, var(--accent) 55%, #a98851 100%);
    box-shadow: var(--shadow);
  }

  .secondary-link,
  .post-link {
    color: var(--text);
    border: 1px solid rgba(200, 169, 107, 0.24);
    background: rgba(200, 169, 107, 0.05);
  }

  .primary-link:hover,
  .secondary-link:hover,
  .post-link:hover {
    transform: translateY(-2px);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    animation: fadeUp 0.6s ease 0.32s both;
  }

  .post-card,
  .empty-card {
    padding: 1.6rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(34, 39, 52, 0.92), rgba(23, 26, 33, 0.92));
    border: 1px solid rgba(200, 169, 107, 0.12);
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }

  .post-date {
    margin: 0 0 0.8rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
  }

  h2 {
    margin: 0;
    color: var(--text);
    font-size: 1.45rem;
    line-height: 1.2;
  }

  .post-excerpt,
  .empty-card p {
    margin: 1rem 0 0;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .post-link {
    margin-top: 1.25rem;
  }

  .empty-state {
    padding-top: 0.5rem;
    animation: fadeUp 0.6s ease 0.32s both;
  }

  .empty-card {
    max-width: 780px;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 960px) {
    .blog-hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-actions {
      justify-content: flex-start;
    }

    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .blog-page {
      padding-inline: 1rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .post-card,
    .empty-card {
      padding: 1.35rem;
    }
  }
</style>
