---
const links = [
  { href: "/about", label: "About Me" },
  { href: "/books", label: "Books" },
  { href: "/blog", label: "Blog" },
];
const authorName = "J.L. Burnes";
const currentPath = Astro.url.pathname;
const instagramUrl = "https://www.instagram.com/jlburnes_author/";
const goodreadsUrl = "https://www.goodreads.com/author/show/67821021.J_L_Burnes";
---

<nav>
  <div class="logo">
    <a
      href="https://en.wikipedia.org/wiki/Moons_of_Jupiter"
      class="logo-mark"
      target="_blank"
      rel="noopener"
      aria-label="Moons of Jupiter"
      title="Moons of Jupiter"
    >
      <span class="europa-orbit europa-back">
        <span class="europa"></span>
      </span>
      <span class="jupiter">
        <span class="jupiter-band band-1"></span>
        <span class="jupiter-band band-2"></span>
        <span class="jupiter-band band-3"></span>
        <span class="jupiter-band band-4"></span>
        <span class="jupiter-surface">
          <span class="jupiter-spot"></span>
        </span>
        <span class="jupiter-glow"></span>
      </span>
      <span class="europa-orbit europa-front">
        <span class="europa"></span>
      </span>
    </a>
    <a href="/" class="logo-copy">
      <span class="logo-name">{authorName}</span>
      <span class="logo-tag">Author</span>
    </a>
  </div>
  <div class="nav-divider" aria-hidden="true">
    <span class="divider-line"></span>
    <span class="divider-glyph"></span>
    <span class="divider-line"></span>
  </div>
  <ul>
    {links.map(link => (
      <li>
        <a
          class:list={["nav-link", currentPath === link.href && "is-active"]}
          href={link.href}
          aria-current={currentPath === link.href ? "page" : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <div class="social-links">
    <a
      class="social-link"
      href={instagramUrl}
      target="_blank"
      rel="noopener"
      aria-label="Follow J.L. Burnes on Instagram"
    >
      <img
        src="https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/svg/instagram.svg"
        alt=""
      />
    </a>
    <a
      class="social-link goodreads-link"
      href={goodreadsUrl}
      target="_blank"
      rel="noopener"
      aria-label="View J.L. Burnes on Goodreads"
    >
      <img
        src="https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/svg/goodreads.svg"
        alt=""
      />
    </a>
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 2rem;
    border-bottom: 1px solid rgba(49, 55, 69, 0.9);
    background:
      linear-gradient(180deg, rgba(20, 23, 30, 0.9), rgba(15, 17, 21, 0.78));
    backdrop-filter: blur(22px);
    position: sticky;
    top: 0;
    z-index: 20;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.2);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    flex: 0 0 auto;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.45rem;
    height: 3.45rem;
    border-radius: 50%;
    overflow: visible;
    position: relative;
    flex: 0 0 auto;
  }

  .logo-mark::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(200, 169, 107, 0.28);
    background:
      radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.08), transparent 42%),
      rgba(200, 169, 107, 0.06);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 8px 24px rgba(0, 0, 0, 0.16);
    z-index: 0;
  }

  .jupiter {
    position: relative;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(circle at 32% 30%, rgba(255, 244, 210, 0.55), transparent 24%),
      radial-gradient(circle at 68% 72%, rgba(130, 82, 48, 0.35), transparent 24%),
      radial-gradient(circle at 30% 30%, rgba(255, 244, 220, 0.16), transparent 28%),
      linear-gradient(180deg, #e5cfaa 0%, #be9368 36%, #8b6248 58%, #d2af86 78%, #a37b5e 100%);
    box-shadow:
      inset -0.35rem -0.35rem 0.55rem rgba(72, 40, 24, 0.28),
      inset 0.25rem 0.18rem 0.45rem rgba(255, 245, 222, 0.18);
    animation: spin-jupiter 18s linear infinite;
    z-index: 2;
  }

  .jupiter-surface {
    position: absolute;
    inset: 0;
    border-radius: 50%;
  }

  .jupiter-spot {
    position: absolute;
    right: 0.38rem;
    top: 1.18rem;
    width: 0.42rem;
    height: 0.28rem;
    border-radius: 999px;
    background: rgba(186, 102, 66, 0.58);
    filter: blur(0.03rem);
    transform: rotate(-10deg);
  }

  .jupiter-band {
    position: absolute;
    left: -6%;
    right: -6%;
    border-radius: 999px;
    opacity: 0.72;
    mix-blend-mode: multiply;
  }

  .band-1 {
    top: 0.38rem;
    height: 0.22rem;
    background: rgba(124, 78, 46, 0.34);
  }

  .band-2 {
    top: 0.82rem;
    height: 0.18rem;
    background: rgba(230, 205, 166, 0.52);
  }

  .band-3 {
    top: 1.12rem;
    height: 0.26rem;
    background: rgba(128, 78, 50, 0.28);
  }

  .band-4 {
    top: 1.52rem;
    height: 0.2rem;
    background: rgba(220, 178, 138, 0.42);
  }

  .jupiter-glow {
    position: absolute;
    inset: -0.08rem;
    border-radius: 50%;
    background: radial-gradient(circle, transparent 68%, rgba(245, 212, 146, 0.12) 100%);
  }

  .europa-orbit {
    position: absolute;
    width: 4.05rem;
    height: 2.8rem;
    left: 50%;
    top: 50%;
    margin-left: -2.025rem;
    margin-top: -1.4rem;
    border-radius: 50%;
    animation: orbit-europa 10s linear infinite;
    transform: rotate(-18deg);
    pointer-events: none;
  }

  .europa-orbit::before {
    content: '';
    position: absolute;
    inset: 0.22rem;
    border-radius: 50%;
    border: 1px solid rgba(200, 169, 107, 0.08);
  }

  .europa {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.42rem;
    height: 0.42rem;
    margin-left: -0.21rem;
    margin-top: -0.21rem;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 35%, rgba(255, 248, 225, 0.9), transparent 38%),
      linear-gradient(180deg, #e8dcc2 0%, #c7b08d 58%, #a48769 100%);
    box-shadow:
      0 0 0.18rem rgba(255, 232, 192, 0.2),
      inset -0.04rem -0.04rem 0.08rem rgba(96, 72, 48, 0.18);
    transform: translateX(1.8rem) scale(0.88);
  }

  .europa-back {
    z-index: 1;
  }

  .europa-front {
    z-index: 3;
    animation-name: orbit-europa, europa-front-visibility;
    animation-duration: 10s, 10s;
    animation-timing-function: linear, steps(1, end);
    animation-iteration-count: infinite, infinite;
  }

  .europa-back .europa {
    animation: europa-back-scale 10s linear infinite;
  }

  .europa-front .europa {
    animation: europa-front-scale 10s linear infinite;
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    color: var(--text);
  }

  .logo-name {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
  }

  .logo-tag {
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1;
  }

  ul {
    display: flex;
    gap: 0.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 0 0 auto;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: auto;
    padding: 0.15rem;
    background: transparent;
    border: 0;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .social-link:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  .social-link img {
    width: 1.45rem;
    height: 1.45rem;
    display: block;
  }

  .social-links {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    flex: 0 0 auto;
  }

  .nav-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1 1 auto;
    opacity: 0.72;
    min-width: 120px;
  }

  .divider-line {
    flex: 1 1 auto;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(200, 169, 107, 0) 0%,
      rgba(200, 169, 107, 0.18) 28%,
      rgba(200, 169, 107, 0.3) 50%,
      rgba(200, 169, 107, 0.18) 72%,
      rgba(200, 169, 107, 0) 100%
    );
  }

  .divider-glyph {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    flex: 0 0 auto;
    border: 1px solid rgba(200, 169, 107, 0.34);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 169, 107, 0.28) 0%, rgba(200, 169, 107, 0.08) 62%, transparent 100%);
    box-shadow: 0 0 0.45rem rgba(200, 169, 107, 0.08);
  }

  .divider-glyph::before,
  .divider-glyph::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: rgba(200, 169, 107, 0.18);
    transform-origin: center;
  }

  .divider-glyph::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .divider-glyph::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0 1.05rem;
    border: 1px solid rgba(200, 169, 107, 0.08);
    border-radius: 999px;
    color: var(--text-muted);
    background: rgba(200, 169, 107, 0.03);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text);
    border-color: rgba(200, 169, 107, 0.22);
    background: rgba(200, 169, 107, 0.08);
    transform: translateY(-1px);
  }

  .nav-link.is-active {
    color: #101216;
    border-color: rgba(200, 169, 107, 0.42);
    background: linear-gradient(135deg, #d7bc86 0%, var(--accent) 55%, #a98851 100%);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 720px) {
    nav {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding: 1rem 1.25rem;
    }

    .logo {
      justify-content: center;
    }

    .nav-divider {
      justify-content: center;
      width: 100%;
      margin: 0 auto;
    }

    ul {
      flex-wrap: wrap;
      gap: 0.6rem;
      justify-content: center;
    }

    .social-links {
      align-self: center;
      justify-content: center;
    }

    .social-link {
      align-self: center;
    }
  }

  @keyframes spin-jupiter {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @keyframes orbit-europa {
    from {
      transform: rotate(-18deg) rotate(0deg);
    }

    to {
      transform: rotate(-18deg) rotate(360deg);
    }
  }

  @keyframes europa-front-visibility {
    0%,
    49.99% {
      opacity: 0;
    }

    50%,
    100% {
      opacity: 1;
    }
  }

  @keyframes europa-front-scale {
    0%,
    49.99% {
      transform: translateX(1.8rem) scale(0.78);
    }

    50% {
      transform: translateX(1.8rem) scale(0.92);
    }

    75% {
      transform: translateX(1.8rem) scale(1);
    }

    100% {
      transform: translateX(1.8rem) scale(0.92);
    }
  }

  @keyframes europa-back-scale {
    0% {
      transform: translateX(1.8rem) scale(0.92);
    }

    25% {
      transform: translateX(1.8rem) scale(1);
    }

    49.99% {
      transform: translateX(1.8rem) scale(0.92);
    }

    50%,
    100% {
      transform: translateX(1.8rem) scale(0.78);
    }
  }
</style>
