---
import background from '../assets/background.svg';
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<main>
		<section id="hero">
			<p class="eyebrow">Dark fantasy. Lasting worlds. Unforgettable characters.</p>
			<h1>Stories built to linger long after the final page.</h1>
			<p class="lede">
				Welcome to the official home of J.L. Burnes. Explore the latest books, meet the
				author behind the stories, and step into a catalog designed to let each cover command
				the room.
			</p>
			<section id="links">
				<a class="button" href="/books">Browse the Books</a>
				<a class="secondary" href="/about">Meet the Author</a>
			</section>
			<section id="highlights">
				<div class="box">
					<span class="label">Featured</span>
					<h2>Designed for cover-first storytelling</h2>
					<p>
						The dark palette stays restrained so your book art can be the brightest, boldest
						element on the page.
					</p>
				</div>
				<div class="box">
					<span class="label">Atmosphere</span>
					<h2>Moody, elegant, and readable</h2>
					<p>
						Soft gold accents bring warmth without pulling attention away from titles,
						summaries, and promotional visuals.
					</p>
				</div>
			</section>
		</section>
	</main>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(120px) saturate(0.15) brightness(0.28);
		opacity: 0.25;
	}

	#container {
		font-family: Georgia, 'Times New Roman', serif;
		min-height: 100vh;
	}

	main {
		min-height: calc(100vh - 88px);
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 3rem 1.5rem 5rem;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		gap: 1.25rem;
		width: min(1100px, 100%);
		padding: 1rem;
	}

	h1 {
		max-width: 11ch;
		font-size: clamp(3.2rem, 9vw, 5.6rem);
		line-height: 0.96;
		letter-spacing: -0.04em;
		margin: 0;
		color: var(--text);
	}

	.eyebrow {
		margin: 0;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.82rem;
	}

	.lede {
		max-width: 43rem;
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--text-muted);
	}

	#links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	#links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0 1.35rem;
		text-decoration: none;
		border-radius: 999px;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	#links a.button {
		color: #101216;
		background: linear-gradient(135deg, #d7bc86 0%, var(--accent) 55%, #a98851 100%);
		box-shadow: var(--shadow);
	}

	#links a.secondary {
		color: var(--text);
		border: 1px solid rgba(200, 169, 107, 0.28);
		background: rgba(200, 169, 107, 0.07);
	}

	#links a:hover {
		transform: translateY(-2px);
	}

	#highlights {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		width: min(840px, 100%);
		margin-top: 1.75rem;
	}

	.label {
		display: inline-block;
		margin-bottom: 0.8rem;
		color: var(--accent);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	h2 {
		margin: 0;
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--text);
	}

	.box p {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.75;
		margin-top: 0.8rem;
	}

	.box {
		padding: 1.5rem;
		background: linear-gradient(180deg, rgba(34, 39, 52, 0.92), rgba(23, 26, 33, 0.92));
		border: 1px solid rgba(200, 169, 107, 0.12);
		border-radius: 24px;
		box-shadow: var(--shadow);
		backdrop-filter: blur(12px);
	}

	@media screen and (max-width: 768px) {
		#hero {
			padding-top: 0;
		}

		#highlights {
			grid-template-columns: 1fr;
		}
	}
</style>
