---
import background from '../assets/background.svg';
import bookCover from '../assets/TheBookOfJacobFrontCover.jpg';
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<main>
		<section id="hero">
			<section id="alpha-callout" aria-label="Alpha reader recruitment">
				<div class="alpha-copy">
					<p class="alpha-kicker">Alpha readers needed</p>
					<h2>Join the early circle and help shape what comes next.</h2>
					<p>
						Read works in progress, share honest feedback, and get a first look at new
						stories before they reach the world.
					</p>
				</div>
				<a
					class="alpha-button"
					href="https://forms.gle/RF7YpYrCwRH1yoL98"
					target="_blank"
					rel="noopener"
				>
					Become an Alpha Reader
				</a>
			</section>
			<p class="eyebrow">Legendary Adventures. Lasting worlds. Unforgettable characters.</p>
			<h1>Stories built to linger long after the final page.</h1>
			<p class="lede">
				Welcome to the official home of J.L. Burnes. Explore the latest books, meet the
				author behind the stories, and step into a world of wonder.
			</p>
			<section id="links">
				<a class="button" href="/books">Browse the Books</a>
				<a class="secondary" href="/about">Meet the Author</a>
			</section>
			<section id="highlights">
				<div class="box">
					<span class="label">Featured</span>
					<div class="featured-book">
						<img src={bookCover.src} alt="The Book of Jacob cover" />
						<div class="featured-copy">
							<h2>The Book of Jacob</h2>
							<p>
								A sweeping post-apocalyptic adventure by J.L. Burnes, available now on
								Amazon.
							</p>
							<a
								class="amazon-cta"
								href="https://amzn.to/4dBlOyh"
								target="_blank"
								rel="noopener"
								aria-label="View The Book of Jacob on Amazon"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 16 16"
									aria-hidden="true"
								>
									<path d="M10.813 11.968c.157.083.36.074.5-.05l.005.005a90 90 0 0 1 1.623-1.405c.173-.143.143-.372.006-.563l-.125-.17c-.345-.465-.673-.906-.673-1.791v-3.3l.001-.335c.008-1.265.014-2.421-.933-3.305C10.404.274 9.06 0 8.03 0 6.017 0 3.77.75 3.296 3.24c-.047.264.143.404.316.443l2.054.22c.19-.009.33-.196.366-.387.176-.857.896-1.271 1.703-1.271.435 0 .929.16 1.188.55.264.39.26.91.257 1.376v.432q-.3.033-.621.065c-1.113.114-2.397.246-3.36.67C3.873 5.91 2.94 7.08 2.94 8.798c0 2.2 1.387 3.298 3.168 3.298 1.506 0 2.328-.354 3.489-1.54l.167.246c.274.405.456.675 1.047 1.166ZM6.03 8.431C6.03 6.627 7.647 6.3 9.177 6.3v.57c.001.776.002 1.434-.396 2.133-.336.595-.87.961-1.465.961-.812 0-1.286-.619-1.286-1.533M.435 12.174c2.629 1.603 6.698 4.084 13.183.997.28-.116.475.078.199.431C13.538 13.96 11.312 16 7.57 16 3.832 16 .968 13.446.094 12.386c-.24-.275.036-.4.199-.299z"/>
									<path d="M13.828 11.943c.567-.07 1.468-.027 1.645.204.135.176-.004.966-.233 1.533-.23.563-.572.961-.762 1.115s-.333.094-.23-.137c.105-.23.684-1.663.455-1.963-.213-.278-1.177-.177-1.625-.13l-.09.009q-.142.013-.233.024c-.193.021-.245.027-.274-.032-.074-.209.779-.556 1.347-.623"/>
								</svg>
								<span>View on Amazon</span>
							</a>
						</div>
					</div>
				</div>
				<div class="box">
					<span class="label">Blog</span>
					<h2>On Writing and Other Things</h2>
					<p>
						Visit the blog for recent posts, behind-the-scenes reflections, and updates from
						J.L. Burnes.
					</p>
					<a class="card-link" href="/blog">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
							<path d="M15 3.604H1v1.891h14v-1.89ZM1 7.208V16l7-3.926L15 16V7.208zM15 0H1v1.89h14z"/>
						</svg>
						<span>Read the Blog</span>
					</a>
				</div>
			</section>
		</section>
	</main>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(120px) saturate(0.15) brightness(0.28);
		opacity: 0.25;
	}

	#container {
		font-family: Georgia, 'Times New Roman', serif;
		min-height: 100vh;
		position: relative;
	}

	main {
		min-height: calc(100vh - 88px);
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 3rem 1.5rem 5rem;
		position: relative;
		z-index: 1;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		gap: 1.25rem;
		width: min(1100px, 100%);
		padding: 1rem;
	}

	h1 {
		max-width: 11ch;
		font-size: clamp(3.2rem, 9vw, 5.6rem);
		line-height: 0.96;
		letter-spacing: -0.04em;
		margin: 0;
		color: var(--text);
		animation: fadeUp 0.6s ease 0.08s both;
	}

	.eyebrow {
		margin: 0;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.82rem;
		animation: fadeUp 0.6s ease both;
	}

	.lede {
		max-width: 43rem;
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--text-muted);
		animation: fadeUp 0.6s ease 0.16s both;
	}

	#links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.25rem;
		animation: fadeUp 0.6s ease 0.3s both;
	}

	#links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0 1.35rem;
		text-decoration: none;
		border-radius: 999px;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	#links a.secondary {
		color: var(--text);
		border: 1px solid rgba(200, 169, 107, 0.28);
		background: rgba(200, 169, 107, 0.07);
	}

	#links a.button {
		color: #101216;
		background: linear-gradient(135deg, #d7bc86 0%, var(--accent) 55%, #a98851 100%);
		box-shadow: var(--shadow);
	}

	#links a:hover {
		transform: translateY(-2px);
	}

	#alpha-callout {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) auto;
		gap: 1.5rem;
		align-items: center;
		width: min(880px, 100%);
		margin-bottom: 0.35rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid rgba(231, 185, 78, 0.42);
		border-radius: 18px;
		background:
			linear-gradient(135deg, rgba(247, 213, 122, 0.16), rgba(126, 82, 42, 0.14)),
			linear-gradient(180deg, rgba(44, 32, 18, 0.92), rgba(29, 22, 15, 0.95));
		box-shadow:
			0 22px 48px rgba(0, 0, 0, 0.3),
			inset 0 1px 0 rgba(255, 243, 212, 0.12);
		overflow: hidden;
		animation: fadeUp 0.6s ease 0.24s both;
	}

	#alpha-callout::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(115deg, transparent 20%, rgba(255, 236, 189, 0.16) 50%, transparent 80%);
		transform: translateX(-55%);
		animation: alphaSweep 6s ease-in-out infinite;
		pointer-events: none;
	}

	.alpha-copy {
		position: relative;
		z-index: 1;
	}

	.alpha-kicker {
		margin: 0 0 0.55rem;
		color: #f4d17a;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.alpha-copy h2 {
		margin: 0;
		font-size: clamp(1.55rem, 4vw, 2.3rem);
		line-height: 1.05;
		max-width: 16ch;
	}

	.alpha-copy p:last-child {
		margin: 0.75rem 0 0;
		max-width: 42rem;
		color: rgba(243, 239, 231, 0.84);
		font-size: 1rem;
		line-height: 1.7;
	}

	.alpha-button {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.5rem;
		padding: 0 1.45rem;
		border-radius: 999px;
		text-decoration: none;
		color: #101216;
		font-weight: 700;
		letter-spacing: 0.02em;
		background: linear-gradient(135deg, #f8dc8f 0%, #e7b94e 52%, #d49a24 100%);
		box-shadow:
			0 18px 34px rgba(0, 0, 0, 0.26),
			inset 0 1px 0 rgba(255, 249, 233, 0.55);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		white-space: nowrap;
	}

	.alpha-button:hover {
		transform: translateY(-2px);
		box-shadow:
			0 22px 40px rgba(0, 0, 0, 0.32),
			inset 0 1px 0 rgba(255, 249, 233, 0.6);
	}

	#highlights {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		width: min(840px, 100%);
		margin-top: 1.75rem;
		animation: fadeUp 0.6s ease 0.34s both;
	}

	.label {
		display: inline-block;
		margin-bottom: 0.8rem;
		color: var(--accent);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	h2 {
		margin: 0;
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--text);
	}

	.box p {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.75;
		margin-top: 0.8rem;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		min-height: 2.8rem;
		margin-top: auto;
		padding: 0 1rem 0 0.9rem;
		border-radius: 999px;
		text-decoration: none;
		color: var(--text);
		border: 1px solid rgba(200, 169, 107, 0.24);
		background: rgba(200, 169, 107, 0.05);
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
		align-self: flex-start;
	}

	.card-link:hover {
		transform: translateY(-2px);
		border-color: rgba(200, 169, 107, 0.38);
		background: rgba(200, 169, 107, 0.09);
	}

	.card-link svg {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
		fill: currentColor;
	}

	.card-link span {
		font-size: 0.94rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	.featured-book {
		display: grid;
		grid-template-columns: 110px minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
		height: 100%;
	}

	.featured-book img {
		width: 100%;
		border-radius: 14px;
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.32);
	}

	.featured-copy p {
		margin-bottom: 0;
	}

	.featured-copy {
		display: flex;
		flex-direction: column;
		min-height: 100%;
	}

	.amazon-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		margin-top: auto;
		min-height: 2.8rem;
		padding: 0 1rem 0 0.9rem;
		border-radius: 999px;
		text-decoration: none;
		color: #101216;
		background: linear-gradient(135deg, #f7d57a 0%, #e7b94e 100%);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		align-self: flex-start;
	}

	.featured-copy p + .amazon-cta {
		margin-top: 1rem;
	}

	.amazon-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.28);
	}

	.amazon-cta svg {
		width: 1.1rem;
		height: 1.1rem;
		flex: 0 0 auto;
		fill: currentColor;
	}

	.amazon-cta span {
		font-size: 0.94rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	.box {
		padding: 1.5rem;
		background: linear-gradient(180deg, rgba(34, 39, 52, 0.92), rgba(23, 26, 33, 0.92));
		border: 1px solid rgba(200, 169, 107, 0.12);
		border-radius: 24px;
		box-shadow: var(--shadow);
		backdrop-filter: blur(12px);
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(16px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes alphaSweep {
		0%,
		100% {
			transform: translateX(-55%);
			opacity: 0.2;
		}

		50% {
			transform: translateX(55%);
			opacity: 0.48;
		}
	}

	@media screen and (max-width: 768px) {
		#hero {
			padding-top: 0;
		}

		#alpha-callout {
			grid-template-columns: 1fr;
			padding: 1.3rem 1.2rem;
		}

		.alpha-copy h2 {
			max-width: 100%;
		}

		.alpha-button {
			width: 100%;
		}

		#highlights {
			grid-template-columns: 1fr;
		}

		.featured-book {
			grid-template-columns: 90px minmax(0, 1fr);
		}
	}
</style>
